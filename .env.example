# Spring profile
SPRING_PROFILES_ACTIVE=dev

# JWT (required)
# Generate a 32-byte Base64 key, e.g.:
# openssl rand -base64 32
BASE64_SECRET_KEY=replace_with_base64_32_bytes_key

# App mail switch
MAIL_ENABLED=false
MAIL_FROM=no-reply@mail.local

# SMTP (dev)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=replace_with_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# App URLs
RESET_PASSWORD_BASE_URL=http://localhost:5173/reset-password
ACCEPT_INVITE_BASE_URL=http://localhost:5173/accept-invite

# Email verification TTL (minutes)
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10

# --- Optional local test overrides ---
# SPRING_PROFILES_ACTIVE=test
# MAIL_ENABLED=false
# MAIL_HOST=localhost
# MAIL_PORT=2525

